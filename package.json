{
  "name": "neicon-explorer",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": ["packages/*"],
  "scripts": {
    "dev": "bun run build:pkg && vite",
    "build": "bun run build:pkg && tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "gen:icons": "node packages/neicon/scripts/generate.mjs && node packages/neicon-react/scripts/generate.mjs",
    "build:pkg": "tsc -p packages/neicon/tsconfig.build.json && tsc -p packages/neicon-react/tsconfig.build.json"
  },
  "dependencies": {
    "neicon-react": "workspace:*",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.1"
  }
}
